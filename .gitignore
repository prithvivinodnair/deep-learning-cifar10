# Data (CIFAR-10 auto-downloads, no need to track)
data/

# Virtual environment
.venv/

# Saved model checkpoints
# Root-level saved_models/ (CIFAR-10 work) is fully ignored — models and
# loose results JSONs were never meant to be tracked.
/saved_models/
# For nested saved_models/ folders (e.g. robotics_analysis/saved_models/),
# only block the binary weights — keep the small results JSONs so reviewers
# can inspect training histories without rerunning the notebooks.
**/saved_models/*.pth
**/saved_models/*.pt
**/saved_models/*.ckpt

# Python cache
__pycache__/
*.pyc
*.pyo

# Jupyter checkpoints
.ipynb_checkpoints/

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# Claude
.claude/
.c/
